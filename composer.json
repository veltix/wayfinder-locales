{
  "name": "veltix/wayfinder-locales",
  "description": "Locale-aware route generation extension for Laravel Wayfinder.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "wayfinder",
    "typescript",
    "i18n",
    "routes"
  ],
  "require": {
    "php": "^8.2",
    "illuminate/routing": "^12.0|^13.0",
    "illuminate/support": "^12.0|^13.0",
    "laravel/wayfinder": "dev-next"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "orchestra/testbench": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Veltix\\WayfinderLocales\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Veltix\\WayfinderLocales\\Providers\\LocalizedRoutesServiceProvider"
      ]
    }
  },
  "config": {
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
